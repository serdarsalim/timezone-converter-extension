{
  "manifest_version": 3,
  "name": "Asr World Clock",
  "version": "2026.3.13",
  "description": "Minimalist time zone converter for Chrome.",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html?surface=sidepanel"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Asr World Clock",
    "default_popup": "popup.html?surface=popup",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
